    Discord={Enabled=false},
    KeySystem=false
})

local c = b:CreateTab("Principal",4483362458)

local d,e,f,g = false,false,false,false

c:CreateToggle({
    Name="🔥 Auto Pesa Súper Rápida",
    CurrentValue=false,
    Flag="s1",
    Callback=function(h)
        d=h
        if h then 
            spawn(function()
                while d do 
                    pcall(function()
                        game:GetService("ReplicatedStorage"):WaitForChild("addStrength"):FireServer()
                    end)
                    task.wait(0.001)
                end 
            end)
        end 
    end
})

