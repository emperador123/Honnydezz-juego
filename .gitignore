        if h then 
            spawn(function()
                while g do 
                    pcall(function()
                        game:GetService("ReplicatedStorage"):WaitForChild("rEvents"):WaitForChild("rebirthEvent"):FireServer()
                    end)
                    task.wait(0.5)
                end 
